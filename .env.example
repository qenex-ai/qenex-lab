# QENEX LAB Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit your .env file to version control!

# ===========================================
# GitHub Integration
# ===========================================
# Personal Access Token for GitHub MCP Server
# Generate at: https://github.com/settings/tokens
# Required scopes: repo, read:org, workflow
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_token_here

# ===========================================
# Optional: Additional MCP Servers
# ===========================================
# Slack Bot Token (if using Slack MCP server)
# SLACK_BOT_TOKEN=xoxb-your-token-here

# Database connection (if using database MCP server)
# DATABASE_URL=postgresql://user:pass@localhost:5432/db

# ===========================================
# QENEX LAB Settings
# ===========================================
# Log level: debug, info, warn, error
LOG_LEVEL=info

# Enable Trinity Pipeline validation
ENABLE_VALIDATION=true

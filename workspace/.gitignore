# QENEX Lab .gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json

# Jupyter
.ipynb_checkpoints/

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Temp files
temp/*
!temp/.gitkeep
*.tmp
*.bak

# Generated reports (keep structure, ignore content)
reports/**/*.pdf
reports/**/*.json
!reports/.gitkeep

# Output files
output/*.pdf
output/*.json
output/*.csv
!output/.gitkeep

# Node modules
node_modules/

# Rust
target/
Cargo.lock
*.rs.bk

# Lock files
bun.lock
package-lock.json

# Secrets (never commit)
.env
.env.*
*.pem
*.key
credentials.json
secrets.json

# Large data files
*.h5
*.hdf5
*.npy
*.npz
*.pkl
*.pickle

# Discovery artifacts (generated)
discoveries.json
optimization_trajectory.csv

# Experiment runs (generated by orchestrator)
experiments/run_*.json

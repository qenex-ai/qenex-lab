{
  "name": "qenex-tissue",
  "version": "0.1.0",
  "description": "QENEX LAB Tissue Distribution ML Engine - AI-powered drug distribution prediction",
  "author": "QENEX LTD",
  "license": "MIT",
  "python_requires": ">=3.10",
  "dependencies": [
    "numpy>=1.24.0"
  ],
  "optional_dependencies": {
    "full": [
      "httpx>=0.24.0",
      "scipy>=1.10.0"
    ],
    "dev": [
      "pytest>=7.0.0",
      "pytest-asyncio>=0.21.0"
    ]
  },
  "entry_points": {
    "console_scripts": [
      "qenex-tissue=main:main"
    ]
  },
  "keywords": [
    "drug-discovery",
    "tissue-distribution",
    "pharmacokinetics",
    "machine-learning",
    "quantum-chemistry",
    "ADMET",
    "BBB",
    "qenex"
  ],
  "classifiers": [
    "Development Status :: 3 - Alpha",
    "Intended Audience :: Science/Research",
    "Topic :: Scientific/Engineering :: Chemistry",
    "Topic :: Scientific/Engineering :: Bio-Informatics",
    "License :: OSI Approved :: MIT License",
    "Programming Language :: Python :: 3.10",
    "Programming Language :: Python :: 3.11",
    "Programming Language :: Python :: 3.12"
  ]
}
